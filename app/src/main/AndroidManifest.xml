<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ===== 权限声明 =====
         注意：以下绝大多数都属于"特殊权限"，runtime 不能用 requestPermissions() 申请，
         必须跳到系统设置由用户手动开启。引导逻辑在 SettingsScreen 里。 -->

    <!-- 通知监听（NLS）用 -->
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE" />

    <!-- 使用统计（UsageStatsManager） -->
    <uses-permission
        android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- 悬浮窗（Phase 4 干预 UI 用） -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- 前台服务 + 唤醒锁（保活/AI 推理时用） -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- 开机自启（NLS 重连辅助） -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- POST_NOTIFICATIONS：Android 13+ 自己发通知需要 runtime 权限 -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 网络（Phase 5 钉钉/超星 API） -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 查询已安装应用列表（按包名分类时需要） -->
    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <application
        android:name=".KhupApplication"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KHUP"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.KHUP">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 通知监听服务。
             exported=true + BIND_NOTIFICATION_LISTENER_SERVICE 是给系统 bind 用的标准模式，
             不会真的开放给其他 App。
             不要放独立进程（android:process=":xxx"），MIUI 更容易杀。 -->
        <service
            android:name=".collection.notification.MessageListener"
            android:label="@string/nls_service_label"
            android:exported="true"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <service
            android:name=".core.intervention.ForegroundAppMonitorService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- WorkManager 默认初始化要禁掉，改用 Hilt 提供的 HiltWorkerFactory -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
